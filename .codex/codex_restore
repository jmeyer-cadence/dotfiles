#!/usr/bin/env bash
# Invoked by tmux-resurrect to restore a Codex session in this pane.
# Falls back with a message if no saved session is found.
RESURRECT_MAP="${HOME}/.codex/resurrect_sessions.json"

if [[ -n "${TMUX_PANE:-}" && -f "$RESURRECT_MAP" ]]; then
    STABLE_ID=$(tmux display-message -p -t "$TMUX_PANE" \
        "#{session_name}:#{window_index}:#{pane_index}" 2>/dev/null)
    if [[ -n "$STABLE_ID" ]]; then
        THREAD_ID=$(RESURRECT_MAP="$RESURRECT_MAP" STABLE_ID="$STABLE_ID" python3 -c "
import json, os
try:
    d = json.load(open(os.environ['RESURRECT_MAP']))
    print(d.get(os.environ['STABLE_ID'], ''))
except Exception:
    pass
" 2>/dev/null)
        if [[ -n "$THREAD_ID" ]]; then
            exec codex resume "$THREAD_ID" "$@"
        fi
    fi
fi

echo "Unable to recover Codex session. Try 'codex resume' to pick from a list of sessions, or 'codex resume --last' to reopen the most recent one."
