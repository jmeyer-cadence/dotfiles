{
    "profiles": [
        {
            "complex_modifications": {
                "rules": [
                    {
                        "description": "Caps Lock → Control (held) / Escape (tapped)",
                        "manipulators": [
                            {
                                "from": {
                                    "key_code": "caps_lock",
                                    "modifiers": { "optional": ["any"] }
                                },
                                "to": [
                                    {
                                        "key_code": "left_control"
                                    }
                                ],
                                "to_if_alone": [{ "key_code": "escape" }],
                                "type": "basic"
                            }
                        ]
                    },
                    {
                        "description": "Window snapping — Ctrl+Cmd+H/L/K",
                        "manipulators": [
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "h",
                                    "modifiers": { "mandatory": ["control", "command"] }
                                },
                                "to": [{ "shell_command": "$HOME/dotfiles/scripts/snap-window.sh left" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "l",
                                    "modifiers": { "mandatory": ["control", "command"] }
                                },
                                "to": [{ "shell_command": "$HOME/dotfiles/scripts/snap-window.sh right" }]
                            },
                            {
                                "type": "basic",
                                "from": {
                                    "key_code": "k",
                                    "modifiers": { "mandatory": ["control", "command"] }
                                },
                                "to": [{ "shell_command": "$HOME/dotfiles/scripts/snap-window.sh maximize" }]
                            }
                        ]
                    }
                ]
            },
            "name": "Default",
            "selected": true,
            "virtual_hid_keyboard": { "keyboard_type_v2": "ansi" }
        }
    ]
}
